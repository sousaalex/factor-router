# ── Provider upstream ──────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Base de dados ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname

# ── Auth0 — admin (/admin/* e modo admin em /usage/*) ───────────
# Authorization: Bearer <access_token> (JWS). Ver test_auth0_admin.py
AUTH0_DOMAIN=dev-xxxx.eu.auth0.com
AUTH0_AUDIENCE=https://api.factor-router.example
# AUTH0_ISSUER=https://dev-xxxx.eu.auth0.com/
# AUTH0_JWT_LEEWAY_SECONDS=10

# ── Servidor (opcionais — já têm defaults) ─────────────────────
PORT=8003
HOST=0.0.0.0
LOG_LEVEL=info
UPSTREAM_TIMEOUT=120
