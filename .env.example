# ── Provider upstream ──────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx
# Opcional: key só para GET /credits (management); senão usa OPENROUTER_API_KEY
# OPENROUTER_MANAGEMENT_API_KEY=sk-or-v1-...
# GET /usage/openrouter/credits: show_alert quando saldo restante (USD) <= limiar
# OPENROUTER_CREDITS_ALERT_THRESHOLD_USD=10
#
# Router económico (snapshot em openrouter_credits_state; actualiza com GET /usage/openrouter/credits):
# OPENROUTER_ROUTER_BUDGET_ENABLED=false — desliga prompt barato + teto de modelo
# OPENROUTER_ROUTER_BUDGET_ENABLED=true
# OPENROUTER_ROUTER_BUDGET_THRESHOLD_USD=25 — limiar só do router (poupar antes do alerta).
#   Omitir esta variável → o router usa o mesmo limiar que OPENROUTER_CREDITS_ALERT_THRESHOLD_USD
# Requer migrations/005_openrouter_credits_state.sql na base (último remaining_usd)

# Modelo premium só para X-User-Id listados (vazio no modelo = desligado)
# GATEWAY_PREMIUM_MODEL=gemini/gemini-3.1-pro-preview
# GATEWAY_PREMIUM_MODEL_USER_ALLOWLIST=user-uuid-1,user-uuid-2
# Se o router escolher o premium e o user não estiver na lista → downgrade (default Kimi)
# GATEWAY_PREMIUM_MODEL_FALLBACK=openrouter/moonshotai/kimi-k2.5

# ── Base de dados ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname

# ── Auth0 — admin (/admin/* e modo admin em /usage/*) ───────────
# Authorization: Bearer <access_token> (JWS). Ver test_auth0_admin.py
AUTH0_DOMAIN=dev-xxxx.eu.auth0.com
AUTH0_AUDIENCE=https://api.factor-router.example
# AUTH0_ISSUER=https://dev-xxxx.eu.auth0.com/
# AUTH0_JWT_LEEWAY_SECONDS=10

# ── Classificador local (router de modelo) — opcional ───────────
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# CLASSIFIER_MODEL=gemma2:2b
# OLLAMA_CLASSIFIER_API=native   # POST /api/chat (Ollama clássico)
# OLLAMA_CLASSIFIER_API=openai   # POST /v1/chat/completions (Ollama recente, LM Studio, …)

# ── Balde por turno (centro de custos) ─────────────────────────
# Maior pausa esperada entre calls ao LLM no mesmo X-Turn-Id (tools lentas, human-in-the-loop).
# Default 30. Turnos longos com pausas de minutos: ex. ACCUMULATOR_IDLE_TTL_SECONDS=3600
# ACCUMULATOR_IDLE_TTL_SECONDS=3600

# ── Servidor (opcionais — já têm defaults) ─────────────────────
PORT=8003
HOST=0.0.0.0
LOG_LEVEL=info
UPSTREAM_TIMEOUT=120
